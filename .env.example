# Hephaestus environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# GitHub Personal Access Token
# Required for: cloning private repos, reading issues, posting comments, opening PRs
# Minimum scopes needed: repo (full), workflow (if triggering Actions)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# ---------------------------------------------------------------------------
# AI provider configuration
# ---------------------------------------------------------------------------
# AI_PROVIDER selects which LLM backend to use.
# Supported values: openai | anthropic | openai-compatible
#
# If AI_PROVIDER is not set, the provider is auto-detected from whichever
# API key is present (ANTHROPIC_API_KEY takes priority over OPENAI_API_KEY).
# When no key is configured, Hephaestus falls back to deterministic planning.
#
# AI_PROVIDER=openai

# Override the model used for planning (optional — sensible defaults apply).
# Examples: gpt-4o, gpt-4o-mini, claude-opus-4-5, claude-3-5-haiku-20241022,
#           mixtral-8x7b-instruct (via an OpenAI-compatible endpoint)
# AI_MODEL=gpt-4o-mini

# OpenAI
# Default model: gpt-4o-mini
# Get a key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic (Claude)
# Default model: claude-3-5-haiku-20241022
# Get a key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# OpenAI-compatible endpoint (Ollama, Groq, LM Studio, Together.ai, etc.)
# Point OPENAI_BASE_URL at your server; set AI_MODEL to the model name.
# Local Ollama example:
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   AI_MODEL=llama3
# OPENAI_BASE_URL=http://localhost:11434/v1

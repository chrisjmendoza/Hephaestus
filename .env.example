# Hephaestus environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# GitHub Personal Access Token
# Required for: cloning private repos, reading issues, posting comments, opening PRs
# Minimum scopes needed: repo (full), workflow (if triggering Actions)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API Key
# Required for: LLM-backed task planning (TaskReasoner)
# Falls back to deterministic planning when absent.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

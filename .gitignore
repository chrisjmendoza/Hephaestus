# Python virtual environments
.venv/
venv/

# Python cache/artifacts
__pycache__/
*.py[cod]
*$py.class

# Runtime logs
logs/*
!logs/.gitkeep
*.log

# Runtime memory artifacts (generated by local runs)
memory/repo_index.json
memory/repo_embeddings.json
memory/task_plan.json
memory/task_report.json
memory/watcher_state.json

# Editor settings
.vscode/

# OS files
.DS_Store
Thumbs.db

# Environment / secrets — never commit these
.env
